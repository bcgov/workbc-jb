# Database connection (must match the PostgreSQL instance used by the rest of WorkBC)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=jobboard
DB_USER=
DB_PASSWORD=

# Elasticsearch / OpenSearch (read path is shared with the .NET search API)
ELASTIC_URL=http://elasticsearch:9200
ELASTIC_USER=
ELASTIC_PASSWORD=

# Index searched for matching jobs (IndexSettings:DefaultIndex)
INDEX_EN=jobs_en

# Safety gate copied from the C# task (AppSettings:IsProduction /
# AppSettings:SendEmailTestingTo): emails are only sent when IS_PRODUCTION
# is true, or when SEND_EMAIL_TESTING_TO redirects every email to a test inbox.
IS_PRODUCTION=false
SEND_EMAIL_TESTING_TO=

# Base URL (no trailing slash) used to build the "view jobs" link in the email
# (AppSettings:JbSearchUrl), e.g. https://www.workbc.ca/jobs
JB_SEARCH_URL=

# Google Maps geocoding key (AppSettings:GoogleMapsIPApi) — used when a saved
# alert has a city/postal radius filter that is not in GeocodedLocationCache yet.
GOOGLE_MAPS_API_KEY=

# Email delivery (EmailSettings:*): SES → SMTP → SendGrid, first enabled wins,
# matching the C# selection order.
EMAIL_USE_SES=false
EMAIL_SES_REGION=ca-central-1
EMAIL_USE_SMTP=false
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=25
EMAIL_SENDGRID_KEY=
EMAIL_SENDGRID_FROM_EMAIL=
EMAIL_FROM_EMAIL=noreply@gov.bc.ca
EMAIL_FROM_NAME=WorkBC.ca No Reply

# Forward proxy for outbound (SendGrid / Google Maps) traffic only —
# Elasticsearch is always addressed directly (ProxySettings:*).
PROXY_USE=false
PROXY_HOST=
PROXY_PORT=80
PROXY_IGNORE_SSL_ERRORS=false

# Per-request HTTP timeout (seconds)
HTTP_TIMEOUT=60

# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
