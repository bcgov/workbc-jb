# ─────────────────────────────────────────────────────────────────────
# WorkBC Job Alert Notifier — environment template
#
# Local runs: copy to .env and fill in. In EKS the CronJob gets these from
# the jb-config2 configmap / jb-secret2 secret (the same objects cli2 and
# the jb-importer-indexer CronJob use) — vars marked [jb-config2] or
# [jb-secret2] already exist there; the rest must be added at cutover.
# ─────────────────────────────────────────────────────────────────────

# PostgreSQL — the shared WorkBC job board database.
# [jb-config2: DB_HOST/DB_PORT/DB_NAME/DB_USER]  [jb-secret2: DB_PASSWORD]
DB_HOST=postgres
DB_PORT=5432
DB_NAME=jobboard
DB_USER=
DB_PASSWORD=

# Elasticsearch / OpenSearch — read-only search path, shared with the web API.
# [jb-config2: ELASTIC_URL/ELASTIC_USER]  [jb-secret2: ELASTIC_PASSWORD]
ELASTIC_URL=http://elasticsearch:9200
ELASTIC_USER=
ELASTIC_PASSWORD=

# Index searched for matching jobs (IndexSettings:DefaultIndex in the old
# .NET appsettings). Default matches production.
INDEX_EN=jobs_en

# Safety gate copied from the C# task (AppSettings:IsProduction /
# AppSettings:SendEmailTestingTo). Emails are sent only when IS_PRODUCTION
# is true, OR when SEND_EMAIL_TESTING_TO redirects every email to a test
# inbox. If neither is set the task logs "No emails were sent" and exits.
#   prod: IS_PRODUCTION=true,  SEND_EMAIL_TESTING_TO=
#   dev:  IS_PRODUCTION=false, SEND_EMAIL_TESTING_TO=LMI.Support@gov.bc.ca
IS_PRODUCTION=false
SEND_EMAIL_TESTING_TO=

# Base URL (no trailing slash) for the "view jobs" link in the email
# (AppSettings:JbSearchUrl). The alert link becomes
# {JB_SEARCH_URL}#/job-search/r;nid={alertId};jsid={userId}
#   dev:  https://dev.workbc.ca/search-and-prepare-job/find-jobs
#   prod: https://www.workbc.ca/search-and-prepare-job/find-jobs
JB_SEARCH_URL=

# Google Maps geocoding key (AppSettings:GoogleMapsIPApi) — only used when a
# saved alert has a city/postal radius filter whose location is not already
# in the GeocodedLocationCache table.  [jb-secret2: GOOGLE_MAPS_API_KEY]
GOOGLE_MAPS_API_KEY=

# Email delivery (EmailSettings:*). First enabled transport wins, matching
# the C# selection order: SES → SMTP → SendGrid.
# Production/dev use SES: the CronJob runs under the ses-mailer-sa service
# account (EKS Pod Identity), so no AWS keys are configured here — the SDK
# default credential chain picks them up automatically.
EMAIL_USE_SES=true
EMAIL_SES_REGION=ca-central-1
EMAIL_USE_SMTP=false
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=25
EMAIL_SENDGRID_KEY=
EMAIL_SENDGRID_FROM_EMAIL=
EMAIL_FROM_EMAIL=noreply@workbc.ca
EMAIL_FROM_NAME=WorkBC.ca No Reply

# Forward proxy for outbound (SendGrid / Google Maps) traffic only —
# Elasticsearch is always addressed directly (ProxySettings:*). Not used in
# the EKS environments.
PROXY_USE=false
PROXY_HOST=
PROXY_PORT=80
PROXY_IGNORE_SSL_ERRORS=false

# Per-request HTTP timeout (seconds)
HTTP_TIMEOUT=60

# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL   [jb-config2: LOG_LEVEL]
LOG_LEVEL=INFO
