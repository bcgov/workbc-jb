# The setting for this file are generated from a Google Sheet.
# Contact mike@oxd.com or pjang@oxd.com if you are authorized to work on the project, and you need the settings
ConnectionStrings__DefaultConnection=
ConnectionStrings__ElasticSearchServer=
ConnectionStrings__Redis=
ConnectionStrings__MigrationRunnerConnection=
IndexSettings__ElasticUser=
IndexSettings__ElasticPassword=
Keycloak__ClientId=
Keycloak__ClientSecret=
AppSettings__GoogleMapsIPApi=
AppSettings__GoogleMapsReferrerApi=
FederalSettings__AuthCookie=
EmailSettings__SendGridKey=
EmailSettings__SendGridFromEmail=
EmailSettings__SmtpServer=
RecaptchaSettings__SiteKey=
RecaptchaSettings__SecretKey=

# ── WorkBC.Importers.Federal.V2 (PHP) ───────────────────────────
# The PHP federal importer reads its config from individual env vars rather
# than appsettings.json. See src/WorkBC.Importers.Federal.V2/.env.example for
# the full list. Minimum required:
DB_HOST=postgres
DB_PORT=5432
DB_NAME=jobboard
DB_USER=
DB_PASSWORD=
FEDERAL_XML_ROOT=https://www.jobbank.gc.ca/xmlfeed
FEDERAL_AUTH_COOKIE=
FEDERAL_PROVINCE_PATH=/en/bc
FEDERAL_INCLUDE_VIRTUAL=true
PROXY_USE=false
PROXY_HOST=dev.forwardproxy.aest.gov.bc.ca
PROXY_PORT=80
PROXY_IGNORE_SSL_ERRORS=true
MAX_JOBS=20000
MAX_ERRORS=25
HTTP_TIMEOUT=30
RETRY_DELAY_MS=5000
LOG_LEVEL=INFO

# ── WorkBC.Importers.Innovibe (PHP) ─────────────────────────────
API_BASE_URL=https://api-prod.jobs.innovibe.ca/api/v1
API_KEY=
PAGE_SIZE=100
INCLUDE_NOC_UNMATCHED=false
