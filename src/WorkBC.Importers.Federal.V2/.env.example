# Database connection (must match the PostgreSQL instance used by the rest of WorkBC)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=jobboard
DB_USER=
DB_PASSWORD=

# Federal Job Bank XML feed
FEDERAL_XML_ROOT=https://www.jobbank.gc.ca/xmlfeed
# Auth cookie required by the IP-whitelisted Federal feed
FEDERAL_AUTH_COOKIE=

# Province slug used to list jobs (defaults to British Columbia + virtual)
FEDERAL_PROVINCE_PATH=/en/bc
FEDERAL_INCLUDE_VIRTUAL=true

# Optional outbound proxy (matches ProxySettings in the legacy C# project)
PROXY_USE=false
PROXY_HOST=dev.forwardproxy.aest.gov.bc.ca
PROXY_PORT=80
PROXY_IGNORE_SSL_ERRORS=true

# Per-run safety limits (mirrors --maxjobs from the legacy CLI)
MAX_JOBS=20000
MAX_ERRORS=25
HTTP_TIMEOUT=30
RETRY_DELAY_MS=5000

# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
